#!/bin/sh

set -e

SCRIPT_DIR="$( cd -- "$( dirname -- "$0" )" &> /dev/null && pwd )"

brew update --force # https://github.com/Homebrew/brew/issues/1151

brew trust --formula grepsedawk/tap/i3wm-osx || true

brew bundle --file=- <<EOF
  brew "ripgrep"
  brew "fzf"
  brew "neovim"
  brew "tree-sitter-cli" # nvim-treesitter main branch compiles parsers via this CLI
  brew "zsh"
  brew "tmux"
  brew "jq"
  brew "wget"
  brew "mosh"
  brew "git-lfs"
  cask "ghostty"

  cask "discord"
  cask "zen"

  brew "gh"
  cask "codex"
  brew "tailscale"

  brew "mise"

  brew "colima"
  brew "docker"
  brew "docker-compose"
  brew "docker-credential-helper"

  tap "grepsedawk/tap"
  brew "i3wm-osx"
EOF

"$SCRIPT_DIR"/../macos/defaults

if [ ! -d ~/.oh-my-zsh ]; then
  git clone git@github.com:robbyrussell/oh-my-zsh.git ~/.oh-my-zsh
fi

# Make brew's zsh the login shell.
BREW_ZSH="$(brew --prefix)/bin/zsh"
if [ -x "$BREW_ZSH" ] && [ "$SHELL" != "$BREW_ZSH" ]; then
  grep -qx "$BREW_ZSH" /etc/shells || echo "$BREW_ZSH" | sudo tee -a /etc/shells >/dev/null
  chsh -s "$BREW_ZSH"
fi

eval "$(mise activate bash)"

mise use --global node@latest

if ! tailscale status >/dev/null 2>&1; then
  echo "==> Starting tailscaled (requires sudo)"
  sudo brew services start tailscale
  sudo tailscale up
fi

if ! colima status >/dev/null 2>&1; then
  echo "==> Starting colima"
  colima start
fi

brew services start i3wm-osx 2>/dev/null || true

cat <<'EOF'

==> Done. Remaining manual steps:
  - Copy ~/.ssh/ and ~/Library/Fonts/MonoLisa* from the old machine
  - Sign in: Bitwarden, Codex (codex login), Claude, Slack, Notion
  - App Store: install anything you want from there
  - Grant i3wm-osx Accessibility + Input Monitoring:
      System Settings → Privacy & Security → Accessibility/Input Monitoring → +
      → /opt/homebrew/opt/i3wm-osx/i3wm-osx.app
  - Log out + back in so keyboard remap, hotkeys, and dark mode fully apply
EOF
