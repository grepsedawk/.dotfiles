#!/bin/bash
# i3wm-osx status line â€” emits i3status JSON protocol.
# Each cycle prints one JSON array of blocks. Bar fills right-to-left,
# so blocks at the end of the array appear leftmost.

set -u

C_OK="#50fa7b"
C_WARN="#f1fa8c"
C_ALERT="#ff5555"
C_PURPLE="#bd93f9"
C_CYAN="#8be9fd"
C_PINK="#ff79c6"
C_ORANGE="#ffb86c"
C_FG="#f8f8f2"
C_DIM="#6272a4"

HAVE_JQ=0
command -v jq >/dev/null 2>&1 && HAVE_JQ=1

NCORES=$(sysctl -n hw.ncpu 2>/dev/null || echo 4)

json_escape() {
  # Escape a string for JSON. Handles \, ", and control chars minimally.
  local s=$1
  s=${s//\\/\\\\}
  s=${s//\"/\\\"}
  printf '%s' "$s"
}

block() {
  local text=$1 color=${2:-$C_FG}
  printf '{"full_text":"%s","color":"%s"}' "$(json_escape "$text")" "$color"
}

# --- collectors ---------------------------------------------------------------

block_time() {
  block "$(date '+%a %b %d  %H:%M:%S')" "$C_FG"
}

block_battery() {
  local raw pct charging icon color
  raw=$(pmset -g batt 2>/dev/null)
  pct=$(printf '%s' "$raw" | grep -oE '[0-9]+%' | head -1 | tr -d '%')
  [[ -z $pct ]] && return 0
  if printf '%s' "$raw" | grep -qiE '; charging'; then
    charging=1
  else
    charging=0
  fi
  if (( charging )); then
    icon="âš¡"
  elif (( pct <= 20 )); then
    icon="ðŸª«"
  else
    icon="ðŸ”‹"
  fi
  if   (( pct > 50 )); then color=$C_OK
  elif (( pct > 20 )); then color=$C_WARN
  else                     color=$C_ALERT
  fi
  block "$icon ${pct}%" "$color"
}

block_wifi() {
  local dev summary connected=0 ssid=""
  dev=$(networksetup -listallhardwareports 2>/dev/null \
    | awk '/^Hardware Port: Wi-Fi/{getline; print $2; exit}')
  dev=${dev:-en0}
  summary=$(ipconfig getsummary "$dev" 2>/dev/null)
  printf '%s' "$summary" | grep -q 'LinkStatusActive : TRUE' && connected=1
  # The i3wm-osx daemon writes "$ssid\t$kind" here (kind=wifi|hotspot)
  # once Location Services is granted.
  local kind=wifi
  if [[ -r /tmp/i3wm-osx-ssid.$UID ]]; then
    IFS=$'\t' read -r ssid kind < /tmp/i3wm-osx-ssid.$UID
  fi
  if (( connected )); then
    local icon="ðŸ“¶"
    [[ $kind == hotspot ]] && icon="ðŸ”—"
    if [[ -n $ssid ]]; then
      block "$icon $ssid" "$C_FG"
    else
      block "$icon" "$C_FG"
    fi
  else
    block "âš  no wifi" "$C_ALERT"
  fi
}

block_load() {
  local load1 pct color
  load1=$(sysctl -n vm.loadavg 2>/dev/null | awk '{print $2}')
  [[ -z $load1 ]] && return 0
  pct=$(awk -v l="$load1" -v n="$NCORES" 'BEGIN { printf "%d", (l/n)*100 + 0.5 }')
  if   (( pct < 70 ));  then color=$C_OK
  elif (( pct < 150 )); then color=$C_WARN
  else                       color=$C_ALERT
  fi
  block "load ${pct}%" "$color"
}

block_mem() {
  # memory_pressure -Q prints "System-wide memory free percentage: NN%"
  local out pct color
  out=$(memory_pressure -Q 2>/dev/null)
  pct=$(printf '%s' "$out" | grep -oE '[0-9]+%' | head -1 | tr -d '%')
  [[ -z $pct ]] && return 0
  if   (( pct > 30 )); then color=$C_OK
  elif (( pct > 10 )); then color=$C_WARN
  else                     color=$C_ALERT
  fi
  block "mem ${pct}%" "$color"
}

block_volume() {
  local vol muted icon settings
  # Single osascript call is far cheaper than two; gate with a timeout
  # because osascript can hang briefly during display-sleep wakeups.
  settings=$(/usr/bin/osascript -e 'tell (get volume settings) to return (output volume as text) & "|" & (output muted as text)' 2>/dev/null)
  vol=${settings%%|*}
  muted=${settings##*|}
  [[ -z $vol || $vol == "missing value" ]] && return 0
  if [[ $muted == "true" ]]; then
    block "ðŸ”‡ muted" "$C_DIM"
  else
    if   (( vol == 0 )); then icon="ðŸ”ˆ"
    elif (( vol < 50 )); then icon="ðŸ”‰"
    else                      icon="ðŸ”Š"
    fi
    block "$icon ${vol}%" "$C_PURPLE"
  fi
}

CLAUDE_CACHE="/tmp/claude/statusline-usage-cache.json"
CLAUDE_CACHE_TTL=60

# Resolve OAuth token from env or macOS Keychain. Prints empty on failure.
claude_oauth_token() {
  if [[ -n ${CLAUDE_CODE_OAUTH_TOKEN:-} ]]; then
    printf '%s' "$CLAUDE_CODE_OAUTH_TOKEN"
    return 0
  fi
  command -v security >/dev/null 2>&1 || return 0
  (( HAVE_JQ )) || return 0
  local blob token
  blob=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null) || return 0
  [[ -z $blob ]] && return 0
  token=$(printf '%s' "$blob" | jq -r '.claudeAiOauth.accessToken // empty' 2>/dev/null)
  [[ -n $token && $token != "null" ]] && printf '%s' "$token"
}

claude_refresh() {
  local token response
  token=$(claude_oauth_token)
  [[ -z $token ]] && return 0
  response=$(curl -s --max-time 8 \
    -H "Accept: application/json" \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer $token" \
    -H "anthropic-beta: oauth-2025-04-20" \
    -H "User-Agent: i3wm-osx-statusline/1.0" \
    "https://api.anthropic.com/api/oauth/usage" 2>/dev/null)
  [[ -z $response ]] && return 0
  printf '%s' "$response" | jq -e '.five_hour' >/dev/null 2>&1 || return 0
  printf '%s' "$response" >"$CLAUDE_CACHE.tmp" && mv "$CLAUDE_CACHE.tmp" "$CLAUDE_CACHE"
}

claude_pct_color() {
  local pct=$1
  if   (( pct >= 90 )); then printf '%s' "$C_ALERT"
  elif (( pct >= 70 )); then printf '%s' "$C_WARN"
  else                       printf '%s' "$C_OK"
  fi
}

block_claude() {
  (( HAVE_JQ )) || return 0
  local now mtime age
  now=$(date +%s)
  if [[ -f $CLAUDE_CACHE ]]; then
    mtime=$(stat -f %m "$CLAUDE_CACHE" 2>/dev/null || echo 0)
    age=$(( now - mtime ))
  else
    age=999999
  fi
  if (( age > CLAUDE_CACHE_TTL )); then
    ( claude_refresh ) &
    disown 2>/dev/null || true
  fi
  [[ -f $CLAUDE_CACHE ]] || return 0

  local data five_pct seven_pct extra_enabled extra_used
  data=$(<"$CLAUDE_CACHE")
  printf '%s' "$data" | jq -e '.five_hour' >/dev/null 2>&1 || return 0

  five_pct=$(printf '%s' "$data" | jq -r '.five_hour.utilization // 0' | awk '{printf "%.0f", $1}')
  seven_pct=$(printf '%s' "$data" | jq -r '.seven_day.utilization // 0' | awk '{printf "%.0f", $1}')
  extra_enabled=$(printf '%s' "$data" | jq -r '.extra_usage.is_enabled // false')

  local parts=()
  if [[ $extra_enabled == "true" ]]; then
    extra_used=$(printf '%s' "$data" | jq -r '(.extra_usage.used_credits // 0) / 100' | awk '{printf "%.2f", $1}')
    parts+=("$(block "\$$extra_used" "$C_FG")")
  fi
  parts+=("$(block "ðŸ¤– 5h ${five_pct}%" "$(claude_pct_color "$five_pct")")")
  parts+=("$(block "7d ${seven_pct}%" "$(claude_pct_color "$seven_pct")")")

  local joined="" first=1 p
  for p in "${parts[@]}"; do
    if (( first )); then joined="$p"; first=0
    else joined="$joined,$p"
    fi
  done
  printf '%s' "$joined"
}

GH_CACHE="/tmp/i3wm-osx-gh-notif.$UID"
GH_CACHE_TTL=120
block_gh() {
  command -v gh >/dev/null 2>&1 || return 0
  local n now mtime age
  now=$(date +%s)
  if [[ -f $GH_CACHE ]]; then
    mtime=$(stat -f %m "$GH_CACHE" 2>/dev/null || echo 0)
    age=$(( now - mtime ))
  else
    age=999999
  fi
  if (( age > GH_CACHE_TTL )); then
    # Refresh in background; this cycle uses the previous value (or skips).
    ( gh api notifications --jq length >"$GH_CACHE.tmp" 2>/dev/null \
        && mv "$GH_CACHE.tmp" "$GH_CACHE" ) &
    disown 2>/dev/null || true
  fi
  [[ -f $GH_CACHE ]] || return 0
  n=$(<"$GH_CACHE")
  [[ -z $n ]] && return 0
  [[ $n =~ ^[0-9]+$ ]] || return 0
  (( n > 0 )) || return 0
  local color=$C_WARN
  (( n >= 5 )) && color=$C_ALERT
  block " $n" "$color"
}

emit() {
  # Order: leftmost first in code, but bar renders right-to-left,
  # so we put time LAST so it appears rightmost.
  local parts=()
  local b
  b=$(block_gh);       [[ -n $b ]] && parts+=("$b")
  b=$(block_claude);   [[ -n $b ]] && parts+=("$b")
  b=$(block_volume);   [[ -n $b ]] && parts+=("$b")
  b=$(block_mem);      [[ -n $b ]] && parts+=("$b")
  b=$(block_load);     [[ -n $b ]] && parts+=("$b")
  b=$(block_wifi);     [[ -n $b ]] && parts+=("$b")
  b=$(block_battery);  [[ -n $b ]] && parts+=("$b")
  b=$(block_time);     [[ -n $b ]] && parts+=("$b")

  local joined="" first=1 p
  for p in "${parts[@]}"; do
    if (( first )); then
      joined="$p"; first=0
    else
      joined="$joined,$p"
    fi
  done
  printf '[%s]\n' "$joined"
}

main() {
  # i3status JSON protocol header (parser tolerates plain JSON arrays too).
  printf '{"version":1}\n[\n'
  while :; do
    emit
    sleep 3
  done
}

# Only run loop when invoked directly, not when sourced for testing.
if [[ ${BASH_SOURCE[0]} == "${0}" ]]; then
  main
fi
