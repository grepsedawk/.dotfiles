#!/bin/bash
# i3wm-osx status line — emits i3status JSON protocol.
# Each cycle prints one JSON array of blocks. Bar fills right-to-left,
# so blocks at the end of the array appear leftmost.

set -u

C_OK="#50fa7b"
C_WARN="#f1fa8c"
C_ALERT="#ff5555"
C_PURPLE="#bd93f9"
C_CYAN="#8be9fd"
C_PINK="#ff79c6"
C_ORANGE="#ffb86c"
C_FG="#f8f8f2"
C_DIM="#6272a4"

HAVE_JQ=0
command -v jq >/dev/null 2>&1 && HAVE_JQ=1

NCORES=$(sysctl -n hw.ncpu 2>/dev/null || echo 4)

json_escape() {
  # Escape a string for JSON. Handles \, ", and control chars minimally.
  local s=$1
  s=${s//\\/\\\\}
  s=${s//\"/\\\"}
  printf '%s' "$s"
}

block() {
  local text=$1 color=${2:-$C_FG}
  printf '{"full_text":"%s","color":"%s"}' "$(json_escape "$text")" "$color"
}

# Pango-markup block: full_text contains <span> tags; the block's own color
# is irrelevant once markup is set.
block_pango() {
  local text=$1
  printf '{"full_text":"%s","markup":"pango"}' "$(json_escape "$text")"
}

# --- collectors ---------------------------------------------------------------

block_time() {
  block "$(date '+%a %b %d  %H:%M:%S')" "$C_FG"
}

block_battery() {
  local raw pct charging icon color
  raw=$(pmset -g batt 2>/dev/null)
  pct=$(printf '%s' "$raw" | grep -oE '[0-9]+%' | head -1 | tr -d '%')
  [[ -z $pct ]] && return 0
  if printf '%s' "$raw" | grep -qiE '; charging'; then
    charging=1
  else
    charging=0
  fi
  if (( charging )); then
    icon="⚡"
  elif (( pct <= 20 )); then
    icon="🪫"
  else
    icon="🔋"
  fi
  if   (( pct > 50 )); then color=$C_OK
  elif (( pct > 20 )); then color=$C_WARN
  else                     color=$C_ALERT
  fi
  block "$icon ${pct}%" "$color"
}

block_wifi() {
  local dev summary connected=0 ssid=""
  dev=$(networksetup -listallhardwareports 2>/dev/null \
    | awk '/^Hardware Port: Wi-Fi/{getline; print $2; exit}')
  dev=${dev:-en0}
  summary=$(ipconfig getsummary "$dev" 2>/dev/null)
  printf '%s' "$summary" | grep -q 'LinkStatusActive : TRUE' && connected=1
  # The i3wm-osx daemon writes "$ssid\t$kind" here (kind=wifi|hotspot)
  # once Location Services is granted.
  local kind=wifi
  if [[ -r /tmp/i3wm-osx-ssid.$UID ]]; then
    IFS=$'\t' read -r ssid kind < /tmp/i3wm-osx-ssid.$UID
  fi
  if (( connected )); then
    local icon="📶"
    [[ $kind == hotspot ]] && icon="🔗"
    local ip
    ip=$(ipconfig getifaddr "$dev" 2>/dev/null)
    local label="$icon"
    [[ -n $ssid ]] && label="$label $ssid"
    [[ -n $ip ]]   && label="$label ($ip)"
    block "$label" "$C_FG"
  else
    block "⚠ no wifi" "$C_ALERT"
  fi
}

block_load() {
  local load1 pct color
  load1=$(sysctl -n vm.loadavg 2>/dev/null | awk '{print $2}')
  [[ -z $load1 ]] && return 0
  pct=$(awk -v l="$load1" -v n="$NCORES" 'BEGIN { printf "%d", (l/n)*100 + 0.5 }')
  if   (( pct < 70 ));  then color=$C_OK
  elif (( pct < 150 )); then color=$C_WARN
  else                       color=$C_ALERT
  fi
  block "load ${pct}%" "$color"
}

block_mem() {
  # memory_pressure -Q prints "System-wide memory free percentage: NN%"
  local out pct color
  out=$(memory_pressure -Q 2>/dev/null)
  pct=$(printf '%s' "$out" | grep -oE '[0-9]+%' | head -1 | tr -d '%')
  [[ -z $pct ]] && return 0
  if   (( pct > 30 )); then color=$C_OK
  elif (( pct > 10 )); then color=$C_WARN
  else                     color=$C_ALERT
  fi
  block "mem ${pct}%" "$color"
}

block_volume() {
  local vol muted icon settings
  # Single osascript call is far cheaper than two; gate with a timeout
  # because osascript can hang briefly during display-sleep wakeups.
  settings=$(/usr/bin/osascript -e 'tell (get volume settings) to return (output volume as text) & "|" & (output muted as text)' 2>/dev/null)
  vol=${settings%%|*}
  muted=${settings##*|}
  [[ -z $vol || $vol == "missing value" ]] && return 0
  if [[ $muted == "true" ]]; then
    block "🔇 muted" "$C_DIM"
  else
    if   (( vol == 0 )); then icon="🔈"
    elif (( vol < 50 )); then icon="🔉"
    else                      icon="🔊"
    fi
    block "$icon ${vol}%" "$C_PURPLE"
  fi
}

CODEX_CACHE="/tmp/codex/statusline-usage-cache.json"
CODEX_CACHE_TTL=60
CODEX_USAGE_URL="${CODEX_USAGE_URL:-https://chatgpt.com/backend-api/wham/usage}"

# ISO-8601 or Unix timestamp to epoch. GNU date first, then BSD fallback.
iso_to_epoch() {
  local iso=$1 stripped epoch
  if [[ $iso =~ ^[0-9]+$ ]]; then
    printf '%s' "$iso"
    return 0
  fi
  epoch=$(date -d "$iso" +%s 2>/dev/null)
  [[ -n $epoch ]] && { printf '%s' "$epoch"; return 0; }
  stripped=${iso%%.*}
  stripped=${stripped%%Z}
  stripped=${stripped%%+*}
  stripped=${stripped%%-[0-9][0-9]:[0-9][0-9]}
  if [[ $iso == *Z* || $iso == *+00:00* || $iso == *-00:00* ]]; then
    epoch=$(env TZ=UTC date -j -f "%Y-%m-%dT%H:%M:%S" "$stripped" +%s 2>/dev/null)
  else
    epoch=$(date -j -f "%Y-%m-%dT%H:%M:%S" "$stripped" +%s 2>/dev/null)
  fi
  [[ -n $epoch ]] && { printf '%s' "$epoch"; return 0; }
  return 1
}

# Style: "time" → 11:19am | "datetime" → may 17, 2:59am
format_reset_time() {
  local iso=$1 style=$2 epoch out
  [[ -z $iso || $iso == null ]] && return 0
  epoch=$(iso_to_epoch "$iso") || return 0
  case $style in
    time)
      out=$(date -j -r "$epoch" +"%l:%M%p" 2>/dev/null || date -d "@$epoch" +"%l:%M%P" 2>/dev/null)
      ;;
    *)
      out=$(date -j -r "$epoch" +"%b %-d, %l:%M%p" 2>/dev/null || date -d "@$epoch" +"%b %-d, %l:%M%P" 2>/dev/null)
      ;;
  esac
  out=${out#"${out%%[! ]*}"}
  printf '%s' "$out" | tr '[:upper:]' '[:lower:]' | sed 's/  / /g'
}

# Resolve the Codex access token from the environment or auth.json.
codex_access_token() {
  if [[ -n ${CODEX_ACCESS_TOKEN:-} ]]; then
    printf '%s' "$CODEX_ACCESS_TOKEN"
    return 0
  fi
  (( HAVE_JQ )) || return 0
  local auth_file="${CODEX_HOME:-$HOME/.codex}/auth.json"
  [[ -r $auth_file ]] || return 0
  jq -r '.tokens.access_token // empty' "$auth_file" 2>/dev/null
}

codex_account_id() {
  if [[ -n ${CODEX_ACCOUNT_ID:-} ]]; then
    printf '%s' "$CODEX_ACCOUNT_ID"
    return 0
  fi
  (( HAVE_JQ )) || return 0
  local auth_file="${CODEX_HOME:-$HOME/.codex}/auth.json"
  [[ -r $auth_file ]] || return 0
  jq -r '.tokens.account_id // empty' "$auth_file" 2>/dev/null
}

codex_refresh() {
  local token account response tmp
  token=$(codex_access_token)
  [[ -z $token ]] && return 0
  account=$(codex_account_id)
  local headers=(
    -H "Accept: application/json"
    -H "Authorization: Bearer $token"
    -H "User-Agent: i3wm-osx-statusline/1.0"
  )
  [[ -n $account ]] && headers+=(-H "ChatGPT-Account-Id: $account")
  response=$(curl -fsS --max-time 8 "${headers[@]}" "$CODEX_USAGE_URL" 2>/dev/null)
  [[ -z $response ]] && return 0
  printf '%s' "$response" | jq -e '.rate_limit.primary_window' >/dev/null 2>&1 || return 0
  mkdir -p "${CODEX_CACHE%/*}"
  tmp="$CODEX_CACHE.tmp.$$"
  printf '%s' "$response" >"$tmp" && mv "$tmp" "$CODEX_CACHE"
}

codex_pct_color() {
  local pct=$1
  if   (( pct >= 90 )); then printf '%s' "$C_ALERT"
  elif (( pct >= 70 )); then printf '%s' "$C_WARN"
  else                       printf '%s' "$C_OK"
  fi
}

codex_window_label() {
  local seconds=$1
  if (( seconds % 604800 == 0 )); then
    printf '%dd' "$(( seconds / 86400 ))"
  elif (( seconds % 3600 == 0 )); then
    printf '%dh' "$(( seconds / 3600 ))"
  else
    printf '%dm' "$(( seconds / 60 ))"
  fi
}

block_codex() {
  (( HAVE_JQ )) || return 0
  local now mtime age
  now=$(date +%s)
  if [[ -f $CODEX_CACHE ]]; then
    mtime=$(stat -f %m "$CODEX_CACHE" 2>/dev/null || echo 0)
    age=$(( now - mtime ))
  else
    age=999999
  fi
  if (( age > CODEX_CACHE_TTL )); then
    ( codex_refresh ) &
    disown 2>/dev/null || true
  fi
  [[ -f $CODEX_CACHE ]] || return 0

  local data
  data=$(<"$CODEX_CACHE")
  printf '%s' "$data" | jq -e '.rate_limit.primary_window' >/dev/null 2>&1 || return 0

  local parts=()
  local name seconds pct reset_at label reset style
  while IFS=$'\t' read -r name seconds pct reset_at; do
    [[ -n $name && $seconds =~ ^[0-9]+$ && $pct =~ ^[0-9]+$ ]] || continue
    label=$(codex_window_label "$seconds")
    parts+=("$(block "${name}${label} ${pct}%" "$(codex_pct_color "$pct")")")
    style=datetime
    (( seconds <= 86400 )) && style=time
    reset=$(format_reset_time "$reset_at" "$style")
    [[ -n $reset ]] && parts+=("$(block "@${reset}" "$C_DIM")")
  done < <(printf '%s' "$data" | jq -r '
    def windows($name; $limit):
      [$limit.primary_window, $limit.secondary_window][]
      | select(. != null)
      | [$name, (.limit_window_seconds // 0), (.used_percent // 0 | round), (.reset_at // 0)]
      | @tsv;
    windows("✨"; .rate_limit)
  ')

  local joined="" first=1 p
  for p in "${parts[@]}"; do
    if (( first )); then joined="$p"; first=0
    else joined="$joined,$p"
    fi
  done
  printf '%s' "$joined"
}

GH_CACHE="/tmp/i3wm-osx-gh-notif.$UID"
GH_CACHE_TTL=120
block_gh() {
  command -v gh >/dev/null 2>&1 || return 0
  local n now mtime age
  now=$(date +%s)
  if [[ -f $GH_CACHE ]]; then
    mtime=$(stat -f %m "$GH_CACHE" 2>/dev/null || echo 0)
    age=$(( now - mtime ))
  else
    age=999999
  fi
  if (( age > GH_CACHE_TTL )); then
    # Refresh in background; this cycle uses the previous value (or skips).
    ( gh api notifications --jq length >"$GH_CACHE.tmp" 2>/dev/null \
        && mv "$GH_CACHE.tmp" "$GH_CACHE" ) &
    disown 2>/dev/null || true
  fi
  [[ -f $GH_CACHE ]] || return 0
  n=$(<"$GH_CACHE")
  [[ -z $n ]] && return 0
  [[ $n =~ ^[0-9]+$ ]] || return 0
  (( n > 0 )) || return 0
  local color=$C_WARN
  (( n >= 5 )) && color=$C_ALERT
  block "GH 🐙 $n" "$color"
}

emit() {
  # Order: leftmost first in code, but bar renders right-to-left,
  # so we put time LAST so it appears rightmost.
  local parts=()
  local b
  b=$(block_gh);       [[ -n $b ]] && parts+=("$b")
  b=$(block_codex);    [[ -n $b ]] && parts+=("$b")
  b=$(block_volume);   [[ -n $b ]] && parts+=("$b")
  b=$(block_mem);      [[ -n $b ]] && parts+=("$b")
  b=$(block_load);     [[ -n $b ]] && parts+=("$b")
  b=$(block_wifi);     [[ -n $b ]] && parts+=("$b")
  b=$(block_battery);  [[ -n $b ]] && parts+=("$b")
  b=$(block_time);     [[ -n $b ]] && parts+=("$b")

  local joined="" first=1 p
  for p in "${parts[@]}"; do
    if (( first )); then
      joined="$p"; first=0
    else
      joined="$joined,$p"
    fi
  done
  printf '[%s]\n' "$joined"
}

main() {
  # i3status JSON protocol header (parser tolerates plain JSON arrays too).
  printf '{"version":1}\n[\n'
  while :; do
    emit
    sleep 3
  done
}

# Only run loop when invoked directly, not when sourced for testing.
if [[ ${BASH_SOURCE[0]} == "${0}" ]]; then
  main
fi
